## Render-Worker Environment Variables.
## Lokal: cp .env.example .env && fill in. Cloud Run: via gcloud run deploy --set-env-vars.

# Supabase — same project als Mobile (für Auth-JWT-Verify + Storage)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # NIEMALS client-side. Nur Server kennt diesen Key.

# Storage Bucket-Namen (Defaults sind OK)
SOURCE_BUCKET=source-uploads
OUTPUT_BUCKET=render-output

# Hard cap auf FFmpeg-Laufzeit (Sekunden). Cloud Run hat 60min request timeout
# als Maximum, aber wir wollen früher abbrechen damit nicht ein verbuggter
# Job die ganze Container-Instanz blockiert.
MAX_DURATION_SEC=300

# PORT wird von Cloud Run automatisch gesetzt (8080 default).
# Lokal: kann hier overridden werden.
PORT=8080
