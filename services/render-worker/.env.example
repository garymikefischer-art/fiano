## Render-Worker Environment Variables.
## Lokal: cp .env.example .env. Cloud Run: via gcloud run deploy --set-env-vars.

# Supabase — für JWT-Auth (NICHT für Storage, da nutzen wir R2)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Cloudflare R2 (S3-kompatibel) — Storage für Source + Output
# Setup: cloudflare.com → R2 → API Tokens → Create API token (Object Read & Write)
R2_ACCOUNT_ID=abc123...                  # Cloudflare-Dashboard → Workers & Pages → Account ID
R2_ACCESS_KEY_ID=...                     # aus API Token
R2_SECRET_ACCESS_KEY=...                 # aus API Token
R2_BUCKET=fiano-renders                  # Bucket-Name (vorher anlegen im Dashboard)

# Render-Limit (Cloud Run timeout ist max 60min, aber wir wollen früher abbrechen)
MAX_DURATION_SEC=300

PORT=8080
