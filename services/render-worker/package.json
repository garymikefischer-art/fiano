{
  "name": "fiano-render-worker",
  "version": "0.1.0",
  "private": true,
  "description": "FFmpeg render worker für fiano Mobile (Phase 9.6). Deployed auf Google Cloud Run.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "docker:build": "docker build -t fiano-render-worker .",
    "docker:run": "docker run -p 8080:8080 --env-file .env fiano-render-worker"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.682.0",
    "@aws-sdk/s3-request-presigner": "^3.682.0",
    "@supabase/supabase-js": "^2.45.4",
    "express": "^4.21.1",
    "express-rate-limit": "^7.5.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
