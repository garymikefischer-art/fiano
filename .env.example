# fiano — Frontend Environment Variables
# Copy this file to .env and fill in real values from your Supabase + Stripe dashboards.
# .env is gitignored — never commit it.
#
# All vars need the VITE_ prefix to be exposed to the renderer (electron-vite convention).

# ─── Supabase ──────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# ─── Stripe (used in Phase 6.2 Pricing) ────────────────────────
VITE_STRIPE_PUBLIC_KEY=pk_test_...
VITE_STRIPE_PRICE_CREATOR=price_...
VITE_STRIPE_PRICE_PRO=price_...
VITE_STRIPE_PRICE_STUDIO_LIFETIME=price_...
