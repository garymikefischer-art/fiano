# Mobile env vars — bei Build via EAS Secrets oder lokal über expo-constants/extra konfigurieren.
# Die Werte sind dieselben wie Desktop's .env (gleiches Supabase-Projekt).
EXPO_PUBLIC_SUPABASE_URL=https://zibzcaknqzxgwootfjxc.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<paste from desktop .env>

# RevenueCat (Mobile-Pendant zu Stripe). Anlegen unter app.revenuecat.com.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxx
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxx
